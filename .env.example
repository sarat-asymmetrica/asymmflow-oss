# AsymmFlow - Environment Configuration
# Copy this to .env and fill in your values

# ═══════════════════════════════════════════════════════════
# OPTIONAL CLOUD SYNC (offline-first — leave ALL of this unset to run
# fully local against the SQLite file; no external database is required)
# ═══════════════════════════════════════════════════════════
# Option 1: Single DATABASE_URL (e.g. a hosting platform's managed PostgreSQL)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option 2: Individual SUPABASE_* variables (legacy support)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-key
# SUPABASE_DB_HOST=db.your-project.supabase.co
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PASSWORD=your-password
# SUPABASE_DB_SSLMODE=require
# SUPABASE_STORAGE_BUCKET=reports

# ═══════════════════════════════════════════════════════════
# AI SERVICES
# ═══════════════════════════════════════════════════════════
MISTRAL_API_KEY=your-mistral-api-key

# ═══════════════════════════════════════════════════════════
# AZURE / MICROSOFT GRAPH (Optional)
# ═══════════════════════════════════════════════════════════
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# ═══════════════════════════════════════════════════════════
# ONEDRIVE PATHS (Optional - for file watcher)
# ═══════════════════════════════════════════════════════════
# ONEDRIVE_RFQ_PATH=C:/Users/YourName/OneDrive/Acme Instrumentation/RFQs
# ONEDRIVE_EH_PATH=C:/Users/YourName/OneDrive/Acme Instrumentation/Supplier Data
# ONEDRIVE_OFFERS_PATH=C:/Users/YourName/OneDrive/Acme Instrumentation/Offers
# ONEDRIVE_INVOICES_PATH=C:/Users/YourName/OneDrive/Acme Instrumentation/Invoices

# ═══════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════
LOG_LEVEL=info
DEBUG_MODE=false
ENABLE_FILE_WATCHER=true
ENABLE_AUTO_BACKUP=false

# ═══════════════════════════════════════════════════════════
# API SERVER (for web deployment)
# ═══════════════════════════════════════════════════════════
# PORT=8080
# ALLOWED_ORIGINS=https://your-app.onrender.com,http://localhost:5173
# RATE_LIMIT_PER_MINUTE=60
