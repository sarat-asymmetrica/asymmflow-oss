-- table invoices
CREATE TABLE `invoices` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`invoice_number` text,`invoice_date` datetime,`customer_id` text,`customer_name` text,`order_id` text,`customer_po_number` text,`grand_total_bhd` decimal(15,3) NOT NULL DEFAULT 0,`status` text DEFAULT "Sent",`outstanding_bhd` decimal(15,3) NOT NULL DEFAULT 0,`subtotal_bhd` decimal(15,3) NOT NULL DEFAULT 0,`due_date` datetime,`updated_by` text,`rfq_id` text,`quote_id` text,`offer_id` text,`offer_number` text,`delivery_note_id` text,`delivery_note_number` text,`total_supplier_cost_bhd` real NOT NULL DEFAULT 0,`gross_margin_bhd` real NOT NULL DEFAULT 0,`gross_margin_percent` real NOT NULL DEFAULT 0,`customer_reference` text,`attention_person` text,`attention_company` text,`attention_phone` text,`attention_address` varchar(1000),`delivery_weeks` text,`country_of_origin` text,`issued_by` text,`contact_phone` text,`discount_percent` real,`payment_terms` varchar(500),`delivery_terms` varchar(500),`division` text,`field_visibility` varchar(1000),`delivery_note_ref` text,`mode_of_payment` text,`suppliers_ref` text,`other_references` text,`buyers_order_number` text,`buyers_order_date` datetime,`despatch_document_no` text,`delivery_note_date` datetime,`despatched_through` text DEFAULT "Direct",`destination` text DEFAULT "Bahrain",`place_of_supply` text DEFAULT "Kingdom of Bahrain",`terms_of_delivery` text DEFAULT "Direct Bank Transfer",`buyer_gstin` text,`ship_to_gstin` text,`place_of_supply_state_code` text,`doc_kind` text DEFAULT "",`reverse_charge` numeric DEFAULT false,`vatbhd` decimal(15,3) NOT NULL DEFAULT 0,`vat_percent` real NOT NULL DEFAULT 0,`journal_entry_id` text,`invoice_hash` text,`notes` text,PRIMARY KEY (`id`),CONSTRAINT `chk_invoices_doc_kind` CHECK (doc_kind IN ('', 'bill_of_supply')),CONSTRAINT `chk_invoices_grand_total_bhd` CHECK (grand_total_bhd >= 0),CONSTRAINT `chk_invoices_outstanding_bhd` CHECK (outstanding_bhd >= 0),CONSTRAINT `chk_invoices_status` CHECK (status IN ('Draft','Sent','Paid','PartiallyPaid','Overdue','Cancelled','Void','Proforma')),CONSTRAINT `chk_invoices_subtotal_bhd` CHECK (subtotal_bhd >= 0),CONSTRAINT `chk_invoices_total_supplier_cost_bhd` CHECK (total_supplier_cost_bhd >= 0),CONSTRAINT `chk_invoices_vat_percent` CHECK (vat_percent >= 0),CONSTRAINT `chk_invoices_vatbhd` CHECK (vatbhd >= 0))

