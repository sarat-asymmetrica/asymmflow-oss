-- table actual_outcomes
CREATE TABLE `actual_outcomes` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`customer_id` text,`was_paid` numeric,PRIMARY KEY (`id`))

-- table alerts
CREATE TABLE `alerts` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`alert_type` text,`severity` text,`title` text,`message` varchar(2000),`is_active` numeric DEFAULT true,`is_acknowledged` numeric DEFAULT false,PRIMARY KEY (`id`),CONSTRAINT `chk_alerts_severity` CHECK (severity IN ('low','medium','high','critical')))

-- table ar_aging_buckets
CREATE TABLE `ar_aging_buckets` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`customer_id` text,`customer_name` text,`snapshot_date` datetime,`less15_days` real,`days16_30` real,`days31_60` real,`days61_90` real,`over90_days` real,`total_outstanding` real,`total_overdue` real,`risk_tier` text,`risk_score` real,`overdue_days` integer,PRIMARY KEY (`id`),CONSTRAINT `chk_ar_aging_buckets_overdue_days` CHECK (overdue_days >= 0),CONSTRAINT `chk_ar_aging_buckets_risk_score` CHECK (risk_score >= 0 AND risk_score <= 1),CONSTRAINT `chk_ar_aging_buckets_risk_tier` CHECK (risk_tier IN ('Low','Medium','High','Critical')))

-- table audit_logs
CREATE TABLE `audit_logs` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`user_id` text,`action` text,`resource` text,`resource_id` text,`description` text,PRIMARY KEY (`id`))

-- table bank_line_payment_allocations
CREATE TABLE `bank_line_payment_allocations` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`bank_statement_line_id` text,`allocation_type` text,`customer_invoice_id` text,`supplier_invoice_id` text,`expense_entry_id` text,`allocated_amount` decimal(15,3),`currency` text DEFAULT "BHD",`status` text DEFAULT "Allocated",PRIMARY KEY (`id`))

-- table chat_messages
CREATE TABLE `chat_messages` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`conversation_id` text,`role` text,`content` text,`tokens_used` integer,`message_type` text DEFAULT "chat",`action_type` text,`action_target` text,`action_label` text,`action_data` text,`action_status` text DEFAULT "none",`action_metadata` text,PRIMARY KEY (`id`),CONSTRAINT `chk_chat_messages_role` CHECK (role IN ('user','assistant','system')),CONSTRAINT `chk_chat_messages_tokens_used` CHECK (tokens_used >= 0))

-- table collaborative_pending_operations
CREATE TABLE `collaborative_pending_operations` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`entity_type` text,`entity_id` text,`operation` text,`payload` text,`status` text DEFAULT "pending",`attempts` integer DEFAULT 0,`last_attempt_at` datetime,`next_attempt_at` datetime,`error_message` text,PRIMARY KEY (`id`))

-- table contract_clauses
CREATE TABLE `contract_clauses` (`id` text,`category` text,`title` text,`text` text,`is_optional` numeric,`payment_grade_minimum` text,`is_protective` numeric,`display_order` integer,`created_at` datetime,`updated_at` datetime,PRIMARY KEY (`id`))

-- table contract_templates
CREATE TABLE `contract_templates` (`id` text,`name` text,`category` text,`description` text,`content` text,`is_active` numeric,`created_at` datetime,`updated_at` datetime,PRIMARY KEY (`id`))

-- table contracts
CREATE TABLE `contracts` (`id` text,`contract_no` text,`customer_id` text,`customer_name` text,`template_id` text,`template_name` text,`contract_type` text,`contract_value_bhd` real,`payment_terms` text,`payment_grade` text,`advance_percent` real,`effective_date` datetime,`expiry_date` datetime,`status` text,`pdf_path` text,`selected_clauses` text,`order_id` text,`created_at` datetime,`updated_at` datetime,`created_by` text,`deleted_at` datetime,PRIMARY KEY (`id`))

-- table conversations
CREATE TABLE `conversations` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`title` text,`summary` varchar(2000),`is_active` numeric DEFAULT true,`last_msg_at` datetime,PRIMARY KEY (`id`))

-- table costing_histories
CREATE TABLE `costing_histories` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`product_id` text,`cost_bhd` real,PRIMARY KEY (`id`))

-- table costing_line_item_data
CREATE TABLE `costing_line_item_data` (`id` text,`costing_sheet_id` integer,`product_number` integer,`equipment` text,`model` text,`specification` text,`supplier` text,`quantity` real,`fob_eur` real,`exchange_rate` real,`total_cost_bhd` real,`markup_percent` real,`selling_price_bhd` real,`total_suggested_bhd` real,`created_at` datetime,`updated_at` datetime,PRIMARY KEY (`id`))

-- table costing_sheet_attachments
CREATE TABLE `costing_sheet_attachments` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`scope_id` text,`costing_number` text,`file_name` text,`file_ext` text,`mime_type` text,`file_size` integer,`file_hash` text,`storage_mode` text DEFAULT "database",`local_path` varchar(1000),`content_base64` text,`notes` text,`uploaded_by` text,PRIMARY KEY (`id`))

-- table costing_sheet_data
CREATE TABLE `costing_sheet_data` (`id` integer PRIMARY KEY AUTOINCREMENT,`rfq_id` integer,`rfq_name` text,`opportunity_id` text,`revision_number` integer DEFAULT 1,`parent_costing_id` integer,`is_active` numeric DEFAULT true,`items` text,`subtotal` real,`total_markup` real,`final_price` real,`margin_percent` real,`status` text DEFAULT "draft",`created_by` text,`approved_by` text,`approval_required` numeric,`risk_warnings` text,`created_at` datetime,`updated_at` datetime,`offer_number` text,`customer_name` text,`product_type` text,`total_value_bhd` real,`line_item_count` integer,`source_file_path` text,`extracted_at` datetime)

-- table credit_note_items
CREATE TABLE `credit_note_items` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`credit_note_id` text,`line_number` integer,`description` varchar(2000),`quantity` real,`rate` real,`total_bhd` decimal(15,3),`hsn_code` text,`uqc` text,PRIMARY KEY (`id`))

-- table credit_notes
CREATE TABLE "credit_notes"  (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`credit_note_number` text,`credit_note_date` datetime,`invoice_id` text,`invoice_number` text,`customer_id` text,`customer_name` text,`reason` varchar(2000),`subtotal_bhd` decimal(15,3),`vatbhd` decimal(15,3),`vat_percent` real,`grand_total_bhd` decimal(15,3),`status` text DEFAULT "Draft",`division` text,`applied_at` datetime,`credit_note_hash` text,PRIMARY KEY (`id`))

-- table customer_contacts
CREATE TABLE `customer_contacts` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`customer_id` text,`contact_name` text,`job_title` text,`email` text,`phone` text,`address` varchar(1000),`is_primary_contact` numeric,`is_primary` numeric,`salutation` text,PRIMARY KEY (`id`))

-- table customer_receipt_allocations
CREATE TABLE `customer_receipt_allocations` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`receipt_id` text,`invoice_id` text,`invoice_number` text,`payment_id` text,`allocated_amount_bhd` decimal(15,3) NOT NULL DEFAULT 0,`allocation_date` datetime,`status` text DEFAULT "Applied",`updated_by` text,PRIMARY KEY (`id`),CONSTRAINT `chk_customer_receipt_allocations_allocated_amount_bhd` CHECK (allocated_amount_bhd >= 0))

-- table customer_receipts
CREATE TABLE `customer_receipts` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`receipt_number` text,`customer_id` text,`customer_name` text,`division` text DEFAULT "PH Trading",`receipt_date` datetime,`amount_bhd` decimal(15,3) NOT NULL DEFAULT 0,`applied_amount_bhd` decimal(15,3) NOT NULL DEFAULT 0,`unapplied_amount_bhd` decimal(15,3) NOT NULL DEFAULT 0,`payment_method` text,`reference` text,`status` text DEFAULT "OnAccount",`notes` text,`updated_by` text,PRIMARY KEY (`id`),CONSTRAINT `chk_customer_receipts_amount_bhd` CHECK (amount_bhd >= 0),CONSTRAINT `chk_customer_receipts_applied_amount_bhd` CHECK (applied_amount_bhd >= 0),CONSTRAINT `chk_customer_receipts_unapplied_amount_bhd` CHECK (unapplied_amount_bhd >= 0))

-- table customer_snapshots
CREATE TABLE `customer_snapshots` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`customer_id` text,`order_value` real,PRIMARY KEY (`id`))

-- table customers
CREATE TABLE `customers` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`customer_id` text,`customer_code` text,`customer_type` text,`business_name` text,`short_code` text,`trading_name` text,`cr_number` text,`status` text DEFAULT "Active",`primary_phone` text,`primary_email` text,`website` text,`address_line1` text,`city` text,`country` text,`trn` text,`mobile_number` text,`tax_code` text,`address` text,`phone` text,`email` text,`industry` text,`relation_years` integer,`payment_grade` text DEFAULT "C",`customer_grade` text DEFAULT "C",`payment_terms_days` integer,`avg_payment_days` real,`dispute_count` integer,`total_orders_value` real,`total_orders_count` integer,`avg_order_value` real,`last_order_date` datetime,`ar_risk_tier` text,`outstanding_bhd` real,`overdue_days` integer,`credit_limit_bhd` real DEFAULT 50000,`is_credit_blocked` numeric DEFAULT false,`requires_prepayment` numeric DEFAULT false,`has_abb_competition` numeric DEFAULT false,`is_emergency_only` numeric DEFAULT false,PRIMARY KEY (`id`))

-- table data_quality_reviews
CREATE TABLE `data_quality_reviews` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`issue_id` text,`issue_type` text,`severity` text,`entity_type` text,`entity_id` text,`summary` text,`detail` text,`primary_action` text,`status` text,`review_note` text,`reviewed_by_id` text,`reviewed_by` text,`reviewed_at` datetime,PRIMARY KEY (`id`))

-- table db_costing_additional_costs
CREATE TABLE `db_costing_additional_costs` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`costing_sheet_id` text,`description` text,`amount_bhd` real NOT NULL DEFAULT 0,PRIMARY KEY (`id`),CONSTRAINT `chk_db_costing_additional_costs_amount_bhd` CHECK (amount_bhd >= 0))

-- table db_costing_items
CREATE TABLE `db_costing_items` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`costing_sheet_id` text,`line_number` integer,`product_id` text,`product_type` text,`description` varchar(2000),`quantity` real NOT NULL DEFAULT 0,`unit_cost_bhd` real NOT NULL DEFAULT 0,`margin_percent` real NOT NULL DEFAULT 0,`unit_price_bhd` real NOT NULL DEFAULT 0,`line_total_bhd` real NOT NULL DEFAULT 0,PRIMARY KEY (`id`),CONSTRAINT `chk_db_costing_items_line_total_bhd` CHECK (line_total_bhd >= 0),CONSTRAINT `chk_db_costing_items_quantity` CHECK (quantity >= 0),CONSTRAINT `chk_db_costing_items_unit_cost_bhd` CHECK (unit_cost_bhd >= 0),CONSTRAINT `chk_db_costing_items_unit_price_bhd` CHECK (unit_price_bhd >= 0))

-- table db_costing_sheets
CREATE TABLE `db_costing_sheets` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`costing_number` text,`customer_id` text,`customer_name` text,`costing_date` datetime,`valid_until` datetime,`subtotal_bhd` real NOT NULL DEFAULT 0,`total_margin_bhd` real NOT NULL DEFAULT 0,`shipping_cost_bhd` real NOT NULL DEFAULT 0,`customs_duty_bhd` real NOT NULL DEFAULT 0,`clearance_cost_bhd` real NOT NULL DEFAULT 0,`handling_cost_bhd` real NOT NULL DEFAULT 0,`additional_costs_bhd` real NOT NULL DEFAULT 0,`grand_total_bhd` real NOT NULL DEFAULT 0,`status` text DEFAULT "Draft",`converted_to_offer_id` text,PRIMARY KEY (`id`),CONSTRAINT `chk_db_costing_sheets_additional_costs_bhd` CHECK (additional_costs_bhd >= 0),CONSTRAINT `chk_db_costing_sheets_clearance_cost_bhd` CHECK (clearance_cost_bhd >= 0),CONSTRAINT `chk_db_costing_sheets_customs_duty_bhd` CHECK (customs_duty_bhd >= 0),CONSTRAINT `chk_db_costing_sheets_grand_total_bhd` CHECK (grand_total_bhd >= 0),CONSTRAINT `chk_db_costing_sheets_handling_cost_bhd` CHECK (handling_cost_bhd >= 0),CONSTRAINT `chk_db_costing_sheets_shipping_cost_bhd` CHECK (shipping_cost_bhd >= 0),CONSTRAINT `chk_db_costing_sheets_status` CHECK (status IN ('Draft','Approved','Converted','Rejected')),CONSTRAINT `chk_db_costing_sheets_subtotal_bhd` CHECK (subtotal_bhd >= 0))

-- table delete_approval_requests
CREATE TABLE `delete_approval_requests` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`entity_type` text,`entity_id` text,`entity_label` text,`requested_by` text,`requested_by_name` text,`requested_role` text,`reason` text,`status` text DEFAULT "pending",`reviewed_by` text,`reviewed_by_name` text,`reviewed_at` datetime,`review_notes` text,PRIMARY KEY (`id`))

-- table delivery_note_items
