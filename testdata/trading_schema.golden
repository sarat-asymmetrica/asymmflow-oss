CREATE TABLE `opportunity_comments` (`id` integer PRIMARY KEY AUTOINCREMENT,`opportunity_id` text,`comment` text,`created_by` text,`created_at` datetime)

-- table opportunity_edit_conflicts
CREATE TABLE `opportunity_edit_conflicts` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`opportunity_id` text,`folder_number` text,`operation` text,`status` text DEFAULT "pending",`expected_version` integer,`current_version` integer,`attempted_by` text,`attempted_role` text,`proposed_changes_json` text,`current_snapshot_json` text,`base_snapshot_json` text,`resolution_action` text,`resolution_note` text,`resolved_by` text,`resolved_at` datetime,PRIMARY KEY (`id`))

-- table order_items
CREATE TABLE `order_items` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`order_id` text,`line_number` integer,`product_id` text,`product_code` text,`description` varchar(2000),`quantity` real,`unit_price` real,`quantity_shipped` real,`quantity_invoiced` real,`equipment` text,`model` text,`specification` varchar(2000),`detailed_description` varchar(5000),`currency` text,`fob` real,`freight` real,`total_cost` real,`margin_percent` real,`total_price` real,`unit_price_bhd` decimal(15,3),`brand` text,`token` text,PRIMARY KEY (`id`))

-- table orders
CREATE TABLE `orders` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`order_number` text,`customer_po_number` text,`customer_id` text,`customer_name` text,`order_date` datetime,`required_date` datetime,`total_value_bhd` decimal(15,3) NOT NULL DEFAULT 0,`grand_total_bhd` decimal(15,3) NOT NULL DEFAULT 0,`status` text DEFAULT "Processing",`updated_by` text,`payment_terms` varchar(500),`delivery_terms` varchar(500),`offer_id` text,`offer_number` text,`rfq_id` text,`customer_reference` text,`attention_person` text,`attention_company` text,`attention_phone` text,`attention_address` varchar(1000),`delivery_weeks` text,`country_of_origin` text,`issued_by` text,`contact_phone` text,`discount_percent` real,`division` text,PRIMARY KEY (`id`),CONSTRAINT `chk_orders_grand_total_bhd` CHECK (grand_total_bhd >= 0),CONSTRAINT `chk_orders_total_value_bhd` CHECK (total_value_bhd >= 0))

-- table payment_prediction_accuracies
CREATE TABLE `payment_prediction_accuracies` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`customer_id` text,`was_accurate` numeric,PRIMARY KEY (`id`))

-- table payments
CREATE TABLE `payments` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`invoice_id` text,`invoice_number` text,`amount_bhd` decimal(15,3) NOT NULL DEFAULT 0,`payment_date` datetime,`payment_method` text,`days_to_payment` integer,`idempotency_key` text,`journal_entry_id` text,`bank_account_id` text,`receipt_id` text,`reference` text,`division` text,`updated_by` text,PRIMARY KEY (`id`),CONSTRAINT `chk_payments_amount_bhd` CHECK (amount_bhd >= 0),CONSTRAINT `chk_payments_days_to_payment` CHECK (days_to_payment >= 0),CONSTRAINT `chk_payments_payment_method` CHECK (payment_method IN ('Cash','Cheque','Bank Transfer','Credit Card','LC','PDC','Other')))

-- table post_sale_notes
CREATE TABLE `post_sale_notes` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`order_id` text,`order_number` text,`note_type` text,`description` varchar(5000),`cost_bhd` real,`note_date` datetime,`resolved_at` datetime,`resolution` varchar(5000),PRIMARY KEY (`id`),CONSTRAINT `chk_post_sale_notes_cost_bhd` CHECK (cost_bhd >= 0),CONSTRAINT `chk_post_sale_notes_note_type` CHECK (note_type IN ('repair','replace','reinstall','warranty','refund','calibration','other')))

-- table prediction_records
CREATE TABLE `prediction_records` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`customer_id` text,`customer_name` text,`grade` text,`predicted_days` integer,`confidence` real,`r1` real,`r2` real,`r3` real,PRIMARY KEY (`id`))

-- table products
CREATE TABLE `products` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`product_code` text,`product_name` text,`product_category` text,`supplier_id` text,`supplier_code` text,`standard_cost_bhd` real,`standard_price_bhd` real,`description` text,`is_active` numeric,`stock_quantity` integer,`sku` text,`part_number` text,`hs_code` text,`unit_of_measure` text,`datasheet_url` varchar(2000),`specifications` varchar(5000),`requires_serial_tracking` numeric DEFAULT false,PRIMARY KEY (`id`))

-- table project_members
CREATE TABLE `project_members` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`project_id` text,`employee_id` text,`role` text,`allocation_percent` real DEFAULT 100,`is_active` numeric DEFAULT true,`joined_at` datetime,`left_at` datetime,PRIMARY KEY (`id`))

-- table projects
CREATE TABLE `projects` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`name` text,`project_type` text DEFAULT "internal",`description` text,`status` text DEFAULT "active",`customer_id` text,`opportunity_id` text,`order_id` text,`customer_name` text,`end_user_name` text,`opportunity_key` text,`customer_poc_name` text,`customer_poc_email` text,`customer_poc_phone` text,`starts_on` datetime,`ends_on` datetime,PRIMARY KEY (`id`))

-- table purchase_order_items
CREATE TABLE `purchase_order_items` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`purchase_order_id` text,`order_item_id` text,`product_id` text,`product_code` text,`supplier_part_number` text,`description` varchar(2000),`quantity` real,`unit_price_foreign` real,`unit_price_bhd` real,`total_foreign` real,`total_bhd` real,`quantity_received` real,PRIMARY KEY (`id`))

-- table purchase_orders
CREATE TABLE `purchase_orders` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`order_id` text,`rfq_id` text,`supplier_id` text,`supplier_name` text,`po_number` text,`po_date` datetime,`expected_delivery` datetime,`currency` text,`exchange_rate` real NOT NULL DEFAULT 1,`subtotal_foreign` real NOT NULL DEFAULT 0,`subtotal_bhd` decimal(15,3) NOT NULL DEFAULT 0,`vat_amount` decimal(15,3) NOT NULL DEFAULT 0,`total_foreign` real NOT NULL DEFAULT 0,`total_bhd` decimal(15,3) NOT NULL DEFAULT 0,`payment_terms` varchar(500),`payment_due_date` datetime,`status` text DEFAULT "Draft",`approved_by` text,`approved_at` datetime,`updated_by` text,`division` text,PRIMARY KEY (`id`),CONSTRAINT `chk_purchase_orders_exchange_rate` CHECK (exchange_rate > 0),CONSTRAINT `chk_purchase_orders_status` CHECK (status IN ('Draft','Pending Approval','Approved','Sent','Acknowledged','Partially Received','Received','Cancelled','Closed')),CONSTRAINT `chk_purchase_orders_subtotal_bhd` CHECK (subtotal_bhd >= 0),CONSTRAINT `chk_purchase_orders_subtotal_foreign` CHECK (subtotal_foreign >= 0),CONSTRAINT `chk_purchase_orders_total_bhd` CHECK (total_bhd >= 0),CONSTRAINT `chk_purchase_orders_total_foreign` CHECK (total_foreign >= 0),CONSTRAINT `chk_purchase_orders_vat_amount` CHECK (vat_amount >= 0))

-- table quick_captures
CREATE TABLE `quick_captures` (`id` integer PRIMARY KEY AUTOINCREMENT,`title` text,`content` text,`tags` text,`priority` text,`status` text,`created_at` datetime,`updated_at` datetime)

-- table rfq_comments
CREATE TABLE `rfq_comments` (`id` integer PRIMARY KEY AUTOINCREMENT,`rfq_id` integer,`comment` text,`created_by` text,`created_at` datetime)

-- table rfq_data
CREATE TABLE `rfq_data` (`id` integer PRIMARY KEY AUTOINCREMENT,`rfq_number` text,`rfq_ref` text,`client` text,`project` text,`value` real,`notes` text,`status` text DEFAULT "pending",`stage` text DEFAULT "RFQ Received",`created_at` datetime,`updated_at` datetime,`document_hash` text,`visit_locations` text,`product_details` text,`source_doc_path` text)

-- table roles
CREATE TABLE `roles` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`name` text,`display_name` text,`description` varchar(1000),`permissions` text,`is_active` numeric DEFAULT true,`is_system` numeric DEFAULT false,PRIMARY KEY (`id`))

-- table serial_numbers
CREATE TABLE `serial_numbers` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`product_id` text,`product_code` text,`serial_no` text,`lot_number` text,`status` text DEFAULT "Available",`po_id` text,`po_number` text,`grn_item_id` text,`grn_number` text,`dn_item_id` text,`dn_number` text,`invoice_id` text,`invoice_number` text,`customer_id` text,`customer_name` text,`received_date` datetime,`shipped_date` datetime,`warranty_start_date` datetime,`warranty_end_date` datetime,`warranty_months` integer,`calibration_date` datetime,`calibration_due_date` datetime,`calibration_cert_path` text,`notes` varchar(2000),PRIMARY KEY (`id`))

-- table settings
CREATE TABLE `settings` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`key` text,`value` varchar(5000),`category` text,`description` varchar(1000),`is_encrypted` numeric DEFAULT false,PRIMARY KEY (`id`))

-- table shipments
CREATE TABLE `shipments` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`order_id` text,`order_number` text,`status` text,`shipment_date` datetime,`delivered_date` datetime,`courier_name` text,`tracking_number` text,PRIMARY KEY (`id`),CONSTRAINT `chk_shipments_status` CHECK (status IN ('Pending','In Transit','Delivered','Failed','Cancelled')))

-- table stock_adjustments
CREATE TABLE `stock_adjustments` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`inventory_item_id` text,`adjustment_date` datetime,`adjustment_type` text,`reason` text,`variance` real,`system_quantity` real,`physical_quantity` real,`unit_cost` real,`value_impact` real,`notes` text,`status` text,`adjustment_number` text,`approved_by` text,`approved_at` datetime,PRIMARY KEY (`id`))

-- table stock_movements
CREATE TABLE `stock_movements` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`inventory_item_id` text,`movement_type` text,`movement_number` text,`quantity` real,`direction` text,`balance_before` real,`balance_after` real,`movement_date` datetime,`reference_type` text,`reference_id` text,`reference_number` text,`counterparty_id` text,`counterparty_name` text,`notes` varchar(2000),`unit_cost` real,`total_value` real,PRIMARY KEY (`id`))

-- table supplier_contacts
CREATE TABLE `supplier_contacts` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`supplier_id` text,`contact_name` text,`job_title` text,`email` text,`phone` text,`address` varchar(1000),`is_primary_contact` numeric,PRIMARY KEY (`id`))

-- table supplier_invoice_items
CREATE TABLE `supplier_invoice_items` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`supplier_invoice_id` text,`line_number` integer,`description` varchar(2000),`quantity` real,`unit_price` real,`total_price` real,`currency` text,PRIMARY KEY (`id`))

-- table supplier_invoices
CREATE TABLE `supplier_invoices` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`supplier_id` text,`supplier_name` text,`purchase_order_id` text,`po_number` text,`grn_id` text,`order_id` text,`invoice_number` text,`invoice_date` datetime,`due_date` datetime,`currency` text,`exchange_rate` real NOT NULL DEFAULT 1,`subtotal_foreign` real NOT NULL DEFAULT 0,`subtotal_bhd` decimal(15,3) NOT NULL DEFAULT 0,`vat_foreign` real NOT NULL DEFAULT 0,`vatbhd` decimal(15,3) NOT NULL DEFAULT 0,`total_foreign` real NOT NULL DEFAULT 0,`total_bhd` decimal(15,3) NOT NULL DEFAULT 0,`match_status` text DEFAULT "Pending",`po_match_ok` numeric,`grn_match_ok` numeric,`status` text DEFAULT "Pending",`approved_by` text,`approved_at` datetime,`updated_by` text,`payment_status` text,`payment_date` datetime,`payment_ref` text,`payment_method` text,`ocr_document_id` text,`ocr_confidence` real,`division` text,`discrepancy_reason` varchar(2000),`dispute_reason` varchar(2000),`journal_entry_id` text,PRIMARY KEY (`id`),CONSTRAINT `chk_supplier_invoices_exchange_rate` CHECK (exchange_rate > 0),CONSTRAINT `chk_supplier_invoices_match_status` CHECK (match_status IN ('Pending','Matched','Discrepancy','Review Required','Dispute')),CONSTRAINT `chk_supplier_invoices_status` CHECK (status IN ('Pending','Approved','Rejected','Paid','Verified','Disputed','Dispute')),CONSTRAINT `chk_supplier_invoices_subtotal_bhd` CHECK (subtotal_bhd >= 0),CONSTRAINT `chk_supplier_invoices_subtotal_foreign` CHECK (subtotal_foreign >= 0),CONSTRAINT `chk_supplier_invoices_total_bhd` CHECK (total_bhd >= 0),CONSTRAINT `chk_supplier_invoices_total_foreign` CHECK (total_foreign >= 0),CONSTRAINT `chk_supplier_invoices_vat_foreign` CHECK (vat_foreign >= 0),CONSTRAINT `chk_supplier_invoices_vatbhd` CHECK (vatbhd >= 0))

-- table supplier_issues
CREATE TABLE `supplier_issues` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`supplier_id` text,`order_ref` text,`description` varchar(5000),`status` text,`resolution` varchar(5000),`cost_bhd` real,`resolved_at` datetime,PRIMARY KEY (`id`),CONSTRAINT `chk_supplier_issues_cost_bhd` CHECK (cost_bhd >= 0),CONSTRAINT `chk_supplier_issues_status` CHECK (status IN ('open','pending','resolved','escalated')))

-- table supplier_payments
CREATE TABLE `supplier_payments` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`supplier_invoice_id` text,`supplier_id` text,`amount_foreign` real NOT NULL DEFAULT 0,`currency` text,`exchange_rate` real NOT NULL DEFAULT 1,`amount_bhd` decimal(15,3) NOT NULL DEFAULT 0,`payment_date` datetime,`payment_method` text,`reference` text,`notes` varchar(2000),`payment_number` text,`journal_entry_id` text,`bank_account_id` text,`updated_by` text,`division` text,`supplier_name` text,`invoice_number` text,PRIMARY KEY (`id`),CONSTRAINT `chk_supplier_payments_amount_bhd` CHECK (amount_bhd >= 0),CONSTRAINT `chk_supplier_payments_amount_foreign` CHECK (amount_foreign >= 0),CONSTRAINT `chk_supplier_payments_exchange_rate` CHECK (exchange_rate > 0),CONSTRAINT `chk_supplier_payments_payment_method` CHECK (payment_method IN ('Bank Transfer','Cheque','LC','Cash','Wire Transfer','PDC','Other')))

-- table suppliers
CREATE TABLE `suppliers` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`supplier_code` text,`supplier_name` text,`country` text,`lead_time_days` integer,`tax_id` text,`supplier_type` text,`brands_handled` varchar(2000),`product_types` varchar(2000),`primary_contact` text,`email` text,`phone` text,`address` varchar(1000),`bank_name` text,`account_number` text,`iban` text,`swift_code` text,`payment_terms` text DEFAULT "Net 30",`rating` integer DEFAULT 3,`notes` varchar(5000),`is_active` numeric,PRIMARY KEY (`id`))

-- table sync_records
CREATE TABLE `sync_records` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`sync_table` text,`record_id` text,`synced_at` datetime,`direction` text,`remote_version` integer,`local_version` integer,`conflict_state` text,PRIMARY KEY (`id`),CONSTRAINT `chk_sync_records_conflict_state` CHECK (conflict_state IN ('none','local_wins','remote_wins')),CONSTRAINT `chk_sync_records_direction` CHECK (direction IN ('push','pull')),CONSTRAINT `chk_sync_records_local_version` CHECK (local_version >= 0),CONSTRAINT `chk_sync_records_remote_version` CHECK (remote_version >= 0))

-- table sync_status
CREATE TABLE `sync_status` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`file_path` text,`status` text,`last_sync_time` datetime,PRIMARY KEY (`id`))

-- table tally_invoice_imports
CREATE TABLE `tally_invoice_imports` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`import_batch` text,`year` integer,`invoice_number` text,`customer_name` text,`matched_customer_id` text,`invoice_date` datetime,`amount` real,`currency` text,`status` text,`raw_data` varchar(5000),PRIMARY KEY (`id`),CONSTRAINT `chk_tally_invoice_imports_amount` CHECK (amount >= 0),CONSTRAINT `chk_tally_invoice_imports_status` CHECK (status IN ('imported','matched','duplicate','error','pending')),CONSTRAINT `chk_tally_invoice_imports_year` CHECK (year >= 2000 AND year <= 2100))

-- table tally_purchase_imports
CREATE TABLE `tally_purchase_imports` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`import_batch` text,`year` integer,`invoice_number` text,`supplier_name` text,`matched_supplier_id` text,`invoice_date` datetime,`amount` real,`currency` text,`status` text,`raw_data` varchar(5000),PRIMARY KEY (`id`),CONSTRAINT `chk_tally_purchase_imports_amount` CHECK (amount >= 0),CONSTRAINT `chk_tally_purchase_imports_status` CHECK (status IN ('imported','matched','duplicate','error','pending')),CONSTRAINT `chk_tally_purchase_imports_year` CHECK (year >= 2000 AND year <= 2100))

-- table task_activity
CREATE TABLE `task_activity` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`task_id` text,`employee_id` text,`activity_type` text,`detail` text,`metadata_json` text,PRIMARY KEY (`id`))

