-- table win_probability_predictions
CREATE TABLE `win_probability_predictions` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`offer_id` text,`predicted_probability` real,PRIMARY KEY (`id`))

