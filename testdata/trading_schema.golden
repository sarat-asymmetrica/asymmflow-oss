-- table delivery_notes
CREATE TABLE `delivery_notes` (`id` text,`created_at` datetime,`updated_at` datetime,`deleted_at` datetime,`version` integer DEFAULT 1,`created_by` text,`order_id` text,`customer_id` text,`dn_number` text,`delivery_date` datetime,`delivery_address` varchar(1000),`contact_person` text,`contact_phone` text,`driver_name` text,`vehicle_number` text,`transport_method` text,`status` text DEFAULT "Prepared",`updated_by` text,`signed_by` text,`signed_at` datetime,`signature_image` text,`is_partial_delivery` numeric,`delivery_sequence` integer,`total_deliveries` integer,PRIMARY KEY (`id`),CONSTRAINT `chk_delivery_notes_status` CHECK (status IN ('Prepared','Dispatched','InTransit','Delivered','Signed','Cancelled')))

-- table device_users
