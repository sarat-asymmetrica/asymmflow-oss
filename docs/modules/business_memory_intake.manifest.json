    "primary_gap": "Business Memory source asset durability, runtime surfacing, and documentation are current; the next implementation gap is the Cashflow Evidence allocation-aware preflight promotion."
  },
  "product_loop": {
    "messy_input": [
      "messages",
      "emails",
      "pdfs",
      "scans",
      "screenshots",
      "excel_files",
      "folders",
      "inbox_records"
    ],
    "canonical_state": "reviewable_intake_candidate",
    "intelligence": [
      "document_classification",
      "field_extraction_status",
      "source_provenance",
      "confidence_mapping",
      "deterministic_link_proposals"
    ],
    "decision_or_action": [
      "review_candidate",
      "correct_field",
      "request_deterministic_link",
      "assemble_butler_context"
    ],
    "audit_trail": "intake_candidate_audit_refs"
  },
  "justification_filters": {
    "roi_proof": "Reduce document hunting, data retyping, accountant/operator context loss, follow-up reconstruction, and evidence chaos across importable business sources.",
    "workflow_closure": "The first slice ends with a canonical candidate that is reviewable, correctable, link-proposed, and auditable before any authoritative business mutation.",
    "engine_leverage": [
      "runtime InboxProcessResult",
      "stored InboxDocument",
      "OCR/extraction maps",
      "document classifier confidence",
      "future Butler TOON context"
    ],
    "operator_trust": [
      "source_kind",
      "source_ref",
      "field_status",
      "confidence",
      "warnings",
      "suggested_deterministic_service",
      "audit_refs"
    ]
  },
