    {
      "name": "approval_queues",
      "status": "future_authority_surface_constraint",
      "note": "Destructive or authoritative actions require explicit operator approval states."
    },
    {
      "name": "sync_conflict_policy",
      "status": "future_sync_contract_constraint",
      "note": "Durable review and source records need module-aware sync envelopes before distributed merge promises."
    },
    {
      "name": "ui_backend_action_inventory",
      "status": "launch_readiness_constraint",
      "note": "Action surfaces should expose command ownership, backend support, and authority level."
    }
  ],
