    ],
    "json_payloads": [
      "pkg/documents/intake.Candidate",
      "pkg/documents/intake.SourceRef",
      "pkg/documents/intake.ExtractedField",
      "pkg/documents/intake.SuggestedLink",
      "pkg/documents/intake.SourceAsset",
      "manifest"
    ],
    "toon_contexts": [
      "business_memory_intake_candidate_context (checkpoint C)"
    ]
  },
  "kernels": [
