# Local Corestore / Hypercore data dirs (P2P storage — never commit)
.mesh-*-store/
*-store/
corestore/
# wasm build output is covered by the root .gitignore (dist/), regenerated via `npm run build`
.peer-host/
.peer-join/

# Sealed-kit build output (Bare campaign). ~48MB — bare.exe alone is 45MB — and
# fully regenerated by `npm run buildbarekit`. NOTE the root .gitignore's `dist/`
# pattern does NOT match `dist-bare/`, so this entry is load-bearing: without it a
# 45MB prebuilt binary lands in the repo on the next `git add -A`.
kit/dist-bare/

# Sealed Corridor addition: build-bare-kit.mjs gained `--out=<dir>` so concurrent
# gates stop wiping each other's kit (each builder RMs its target before writing).
# Every alternate output directory is the same 45MB+ disposable artifact as
# dist-bare/ above, so the ignore rule has to travel with the parameter — one
# uncovered `--out=` and a prebuilt binary lands in the repo on the next
# `git add -A`. Convention: any sealed-kit output dir under kit/ starts with a dot.
kit/.sc0-gatecheck/
kit/.sc1-dist/
kit/.sc2-dist/
kit/.sc3-dist/
kit/.sc4-dist/

# Disposable spike storage/fixture dirs (created and removed by the spikes
# themselves; listed so an interrupted run can't leave a committable stray).
.bare-bridge-worker-storage/
.bare-bridge-spike-*/
host/.stdio-seam-tmp/

# Runtime data written by the kit/guide when run from the repo (DP1 plane layout:
# data/corestore + data/keys as siblings). The `corestore/` rule above already
# catches the store, but NOT data/keys/ — and that holds real key material. Ignore
# the whole plane rather than relying on a partial match.
data/
kit/.gate-worker-storage/
