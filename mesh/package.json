{
  "name": "@asymmflow/mesh",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Sovereign Mesh track for AsymmFlow — the Go kernel as a deterministic Autobase apply() reducer over Hypercore/Corestore, replicated across Holesail P2P tunnels. See ../FABLE_CAMPAIGN_SOVEREIGN_MESH.md.",
  "scripts": {
    "build": "node scripts/build-reducer.mjs",
    "smoke": "npm run build && node host/smoke.mjs",
    "smoke:update-golden": "npm run build && node host/smoke.mjs --update-golden",
    "wave1": "npm run build && node host/wave1-local.mjs",
    "wave1:update-golden": "npm run build && node host/wave1-local.mjs --update-golden",
    "wave1:holesail": "npm run build && node host/wave1-holesail.mjs",
    "missionc": "npm run build && node host/missionc-mesh.mjs",
    "missionc:update-golden": "npm run build && node host/missionc-mesh.mjs --update-golden",
    "wave1:host": "node host/peer.mjs host --storage ./.peer-host",
    "wave1:join": "node host/peer.mjs join --storage ./.peer-join",
    "test:go": "cd .. && go test ./mesh/..."
  },
  "dependencies": {
    "autobase": "^7.11.0",
    "corestore": "^7.4.0",
    "holesail": "^2.0.0",
    "hyperbee": "^2.24.0",
    "hypercore": "^11.10.0",
    "hyperswarm": "^4.11.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "AGPL-3.0"
}
