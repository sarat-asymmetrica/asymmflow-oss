{
  "name": "@asymmflow/mesh",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Sovereign Mesh track for AsymmFlow — the Go kernel as a deterministic Autobase apply() reducer over Hypercore/Corestore, replicated across Holesail P2P tunnels. See ../FABLE_CAMPAIGN_SOVEREIGN_MESH.md.",
  "imports": {
    "#apply": {
      "bare": "./host/apply-bare.mjs",
      "default": "./host/apply.mjs"
    },
    "#fs": {
      "bare": "bare-fs",
      "default": "fs"
    },
    "#crypto": {
      "bare": "bare-crypto",
      "default": "crypto"
    }
  },
  "scripts": {
    "build": "node scripts/build-reducer.mjs",
    "smoke": "npm run build && node host/smoke.mjs",
    "smoke:update-golden": "npm run build && node host/smoke.mjs --update-golden",
    "wave1": "npm run build && node host/wave1-local.mjs",
    "wave1:update-golden": "npm run build && node host/wave1-local.mjs --update-golden",
    "wave1:holesail": "npm run build && node host/wave1-holesail.mjs",
    "missionc": "npm run build && node host/missionc-mesh.mjs",
    "missionc:update-golden": "npm run build && node host/missionc-mesh.mjs --update-golden",
    "mirrorspike": "npm run build && node host/mirror-spike.mjs",
    "mirrorspike:update-golden": "npm run build && node host/mirror-spike.mjs --update-golden",
    "attachspike": "npm run build && node host/attach-spike.mjs",
    "attachspike:update-golden": "npm run build && node host/attach-spike.mjs --update-golden",
    "invitespike": "npm run build && node host/invite-spike.mjs",
    "invitespike:update-golden": "npm run build && node host/invite-spike.mjs --update-golden",
    "roomspike": "npm run build && node host/room-spike.mjs",
    "roomspike:update-golden": "npm run build && node host/room-spike.mjs --update-golden",
    "transcriptspike": "npm run build && node host/transcript-spike.mjs",
    "transcriptspike:update-golden": "npm run build && node host/transcript-spike.mjs --update-golden",
    "reissuespike": "npm run build && node host/reissue-spike.mjs",
    "reissuespike:update-golden": "npm run build && node host/reissue-spike.mjs --update-golden",
    "socialspike": "npm run build && node host/social-spike.mjs",
    "socialspike:update-golden": "npm run build && node host/social-spike.mjs --update-golden",
    "bridgespike": "npm run build && node host/bridge-spike.mjs",
    "kitspike": "npm run build && node kit/kit-spike.mjs",
    "buildkit": "node kit/build-kit.mjs",
    "kit:host": "node kit/kit-host.mjs",
    "missiond": "npm run build && node host/missiond-mesh.mjs",
    "missiond:update-golden": "npm run build && node host/missiond-mesh.mjs --update-golden",
    "missiond:holesail": "npm run build && node host/missiond-holesail.mjs",
    "missiond:host": "node host/peer.mjs host --storage ./.peer-host-d --authority",
    "missiond:join": "node host/peer.mjs join --storage ./.peer-join-d",
    "wave1:host": "node host/peer.mjs host --storage ./.peer-host",
    "wave1:join": "node host/peer.mjs join --storage ./.peer-join",
    "test:go": "cd .. && go test ./mesh/...",
    "bareparity": "npm run build && node host/bare-parity-spike.mjs",
    "bareparity:bare": "npx bare host/bare-parity-spike.mjs",
    "harnessselftest": "node host/spawn-pipe-harness.mjs --selftest",
    "stdioseam": "npm run build && node host/stdio-seam-spike.mjs",
    "buildbarekit": "npm run build && node kit/build-bare-kit.mjs"
  },
  "dependencies": {
    "autobase": "^7.11.0",
    "blind-peer": "^3.12.2",
    "blind-peering": "^2.4.1",
    "corestore": "^7.4.0",
    "holesail": "^2.0.0",
    "hyperbee": "^2.24.0",
    "hyperblobs": "^2.12.1",
    "hypercore": "^11.10.0",
    "hypercore-id-encoding": "^1.3.0",
    "hyperdht": "^6.33.0",
    "hyperswarm": "^4.11.0",
    "protomux-wakeup": "^2.9.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "AGPL-3.0",
  "devDependencies": {
    "bare": "^1.30.3",
    "bare-crypto": "^1.15.3",
    "bare-events": "^2.9.1",
    "bare-fs": "^4.7.4",
    "bare-pack": "^2.2.1",
    "bare-process": "^4.5.1",
    "bare-readline": "^1.3.1",
    "bare-stream": "^2.13.3",
    "bare-subprocess": "^6.1.0"
  }
}
